# AI R&D Council — Environment Variables
# Copy this to .env and fill in your values

# Required: OpenAI API key (used for multiple model personas)
OPENAI_API_KEY=sk-...

# Optional: Email delivery (Gmail SMTP or any SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Optional: SMS notifications via Twilio
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Optional: ntfy push notifications
# Install the ntfy app on your phone and subscribe to your topic
# Default topic: fbf-rd-council
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=fbf-rd-council
